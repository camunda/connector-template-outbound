{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Task Info",
  "id": "4d0fa736-27ec-4072-bc26-3a25e7797984",
  "version": 1760081259688,
  "description": "Get task metadata via connector",
  "icon": {
    "contents": "data:image/png;base64,"
  },
  "appliesTo": [
    "bpmn:Task"
  ],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "properties": [
	  {
	    "label": "Tasklist Address",
	    "description": "IP of Tasklist",
	    "type": "String",
	    "feel": "optional",
	    "binding": {
	      "type": "zeebe:input",
	      "name": "tasklistAddress"
	    },
	    "constraints": {
	      "notEmpty": true
	    }
	  },
	  {
		  "label": "Operate Address",
		  "description": "IP of Operate",
		  "type": "String",
		  "feel": "optional",
		  "binding": {
		    "type": "zeebe:input",
		    "name": "operateAddress"
		  },
		  "constraints": {
		    "notEmpty": true
		  }
	  },
	  {
	    "label": "Keycloak Address",
	    "description": "IP of Keycloak",
	    "type": "String",
	    "feel": "optional",
	    "binding": {
	      "type": "zeebe:input",
	      "name": "keycloakAddress"
	    },
	    "constraints": {
	      "notEmpty": true
	    }
	  },
	  {
		  "label": "ClientSecret",
		  "description": "clientSecret of the client",
		  "type": "String",
		  "feel": "optional",
		  "binding": {
		    "type": "zeebe:input",
		    "name": "clientSecret"
		  },
		  "constraints": {
		    "notEmpty": true
		  }
	  },
	  {
		  "label": "ClientId",
		  "description": "ClientId in Keycloak",
		  "type": "String",
		  "feel": "optional",
		  "binding": {
		    "type": "zeebe:input",
		    "name": "clientId"
		  },
		  "constraints": {
		    "notEmpty": true
		  }
	  },
	  {
	    "label": "Process Instance",
	    "description": "The instance number of the process",
	    "type": "Number",
	    "feel": "optional",
	    "binding": {
	      "type": "zeebe:input",
	      "name": "processInstance"
	    },
	    "constraints": {
	      "notEmpty": true
	    }
	  },
	  {
	    "label": "State",
	    "description": "Select the state",
	    "type": "Dropdown",
	    "value": "CREATED",
	    "choices": [
		  { "name": "CREATED", "value": "CREATED" },
	      { "name": "COMPLETE", "value": "COMPLETE" },
	      { "name": "CANCELED", "value": "CANCELED" }
	    ],
	    "binding": {
	      "type": "zeebe:input",
	      "name": "state"
	    },
	    "constraints": {
	      "notEmpty": true
	    }
	  },
	  {
	    "label": "Result Variable",
	    "description": "Variable to store the result",
	    "type": "String",
	    "value": "taskInfoResult",
	    "binding": {
	      "type": "zeebe:taskHeader",
	      "key": "resultVariable"
	    }
	  },
	  {
	    "label": "Retries",
	    "description": "Number of attempts in case of failure",
	    "type": "String",
	    "value": "3",
	    "binding": {
	      "type": "zeebe:taskDefinition",
	      "property": "retries"
	    }
	  },
        {
	      "type": "Hidden",
	      "value": "io.camunda:task-info:1",
	      "binding": {
	        "type": "zeebe:taskDefinition",
	        "property": "type"
        }
      }
  ]
}